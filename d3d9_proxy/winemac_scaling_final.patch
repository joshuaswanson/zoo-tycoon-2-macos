+    /* Zoo Tycoon 2: pin view to 640x480 after flush to keep GL framebuffer
+       at game resolution. The view gets auto-resized by the window, so we
+       reset it here on every frame. The layer transform in windowDidResize
+       handles the visual scaling. */
+    if (macdrv_scaling_active) {
