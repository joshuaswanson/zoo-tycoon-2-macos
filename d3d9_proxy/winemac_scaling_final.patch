+            if (win && [[win title] containsString:@"Zoo Tycoon 2"] && [[win title] length] < 20) {
+                dispatch_async(dispatch_get_main_queue(), ^{
+                    [view setFrameSize:NSMakeSize(640, 480)];
+                });
+            }
+        }
+    }
+
     [pool release];
 }
